# Project Settings
PROJECT_NAME="Perspective Prism MVP"

# LLM API Configuration
# Gemini API Key (required for claim extraction and analysis)
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=google
LLM_MODEL=gemini-3.5-flash
MAX_CLAIMS_PER_ANALYSIS=15

# Backup / Fallback Configuration
BACKUP_LLM_API_KEY=your_backup_gemini_api_key_here
BACKUP_LLM_MODEL=gemini-3.1-flash-lite

# Reliability Settings
CIRCUIT_BREAKER_FAIL_THRESHOLD=3
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# Google Search API Settings
# Get these from Google Cloud Console (Custom Search JSON API)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CSE_ID=your-custom-search-engine-id-here
SEARCH_PROVIDER=google

# CORS Settings
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS="http://localhost:5173,http://localhost:3000,chrome-extension://nanlbdgphpjpdmIbfinajkhglclanlfe"
